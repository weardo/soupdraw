{
  "manifest_version": 3,
  "name": "SoupDraw: gesture camera drawing",
  "version": "1.0.0",
  "author": "Soup Up",
  "homepage_url": "https://soupdraw.soupup.ai",
  "description": "Draw on your live camera feed with hand gestures, for any video call. Everything runs on-device; nothing leaves your machine.",
  "browser_specific_settings": {
    "gecko": {
      "id": "soupdraw@soupup.ai",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "scripts": ["src/background.js"]
  },
  "commands": {
    "toggle-draw": {
      "suggested_key": { "default": "Alt+Shift+D", "mac": "Command+Shift+D" },
      "description": "Arm/disarm SoupDraw gesture drawing"
    },
    "undo": {
      "suggested_key": { "default": "Alt+Shift+Z", "mac": "Command+Shift+Z" },
      "description": "SoupDraw: undo last action"
    },
    "redo": {
      "suggested_key": { "default": "Alt+Shift+Y", "mac": "Command+Shift+Y" },
      "description": "SoupDraw: redo"
    }
  },
  "action": {
    "default_title": "SoupDraw",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start",
      "js": ["src/content/bridge.js", "src/content/recognizer.js"]
    },
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start",
      "world": "MAIN",
      "js": ["vendor/fingerpose/fingerpose.js", "src/page/engine.js", "src/page/bindings.js", "src/page/pipeline.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["vendor/tasks-vision/*", "src/offscreen/recognizer.html", "src/offscreen/recognizer-frame.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
